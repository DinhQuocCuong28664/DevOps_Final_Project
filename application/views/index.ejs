<%- include('partials/head') %>

  <!-- Search & Filter Bar -->
  <div class="row mb-3 g-2">
    <div class="col-md-5">
      <form id="search-form" method="GET" action="/" class="d-flex gap-2">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Search products..." value="<%= search %>">
        <button type="submit" class="btn btn-outline-primary btn-sm">Search</button>
        <% if (search) { %>
          <a href="/" class="btn btn-outline-secondary btn-sm">Clear</a>
        <% } %>
      </form>
    </div>
    <div class="col-md-3">
      <select id="category-filter" class="form-select form-select-sm" onchange="window.location='/?'+new URLSearchParams({...Object.fromEntries(new URLSearchParams(location.search)), category:this.value, page:1})">
        <option value="">All Categories</option>
        <% categories.forEach(function(c){ %>
          <option value="<%= c.id %>" <%= selectedCategory === c.id ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-2">
      <select id="sort-select" class="form-select form-select-sm" onchange="applySort(this.value)">
        <option value="">Sort: Default</option>
        <option value="price_asc" <%= sortBy === 'price' && order === 'asc' ? 'selected' : '' %>>Price: Low to High</option>
        <option value="price_desc" <%= sortBy === 'price' && order === 'desc' ? 'selected' : '' %>>Price: High to Low</option>
        <option value="name_asc" <%= sortBy === 'name' && order === 'asc' ? 'selected' : '' %>>Name: A-Z</option>
        <option value="name_desc" <%= sortBy === 'name' && order === 'desc' ? 'selected' : '' %>>Name: Z-A</option>
      </select>
    </div>
    <div class="col-md-2 text-end">
      <button id="btn-add" class="btn btn-primary btn-sm w-100">+ Add Product</button>
    </div>
  </div>

  <!-- Product Count -->
  <div class="mb-2 text-muted small">
    Showing <%= products.length %> of <%= pagination.total %> products
  </div>

  <!-- Products Table -->
  <div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
      <thead class="table-dark">
        <tr>
          <th style="width:80px">Photo</th>
          <th>Name</th>
          <th>Price</th>
          <th>Color</th>
          <th>Category</th>
          <th>Description</th>
          <th style="width:140px">Actions</th>
        </tr>
      </thead>
      <tbody id="product-table">
        <% if (products.length === 0) { %>
          <tr><td colspan="7" class="text-center text-muted py-4">No products found</td></tr>
        <% } %>
        <% products.forEach(function(p){ %>
          <tr data-id="<%= p.id %>" data-image="<%= p.imageUrl || '' %>" data-category="<%= p.category || '' %>">
            <td>
              <img src="<%= p.imageUrl && p.imageUrl.length ? p.imageUrl : '/images/placeholder-80.png' %>" alt="thumb" class="img-thumbnail" style="width:60px;height:60px;object-fit:cover">
            </td>
            <td><%= p.name %></td>
            <td>$<%= Number(p.price).toFixed(2) %></td>
            <td><%= p.color %></td>
            <td><%= p.category ? (categories.find(c => c.id === p.category)?.name || 'N/A') : 'N/A' %></td>
            <td><%= p.description || '' %></td>
            <td>
              <button class="btn btn-sm btn-outline-secondary btn-edit">Edit</button>
              <button class="btn btn-sm btn-outline-danger btn-delete">Delete</button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (pagination.totalPages > 1) { %>
  <nav>
    <ul class="pagination pagination-sm justify-content-center">
      <li class="page-item <%= pagination.hasPrev ? '' : 'disabled' %>">
        <a class="page-link" href="?<%= buildQueryString(Object.assign({}, {search, category, sortBy, order, page: pagination.page - 1})) %>">Previous</a>
      </li>
      <% for (let i = 1; i <= pagination.totalPages; i++) { %>
        <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
          <a class="page-link" href="?<%= buildQueryString(Object.assign({}, {search, category, sortBy, order, page: i})) %>"><%= i %></a>
        </li>
      <% } %>
      <li class="page-item <%= pagination.hasNext ? '' : 'disabled' %>">
        <a class="page-link" href="?<%= buildQueryString(Object.assign({}, {search, category, sortBy, order, page: pagination.page + 1})) %>">Next</a>
      </li>
    </ul>
  </nav>
  <% } %>

  <!-- Modal Form -->
  <div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <form id="product-form">
          <div class="modal-header">
            <h5 class="modal-title" id="modalTitle">Add Product</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <input type="hidden" id="product-id">
            <div class="mb-3">
              <label class="form-label">Name</label>
              <input id="name" name="name" type="text" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Price</label>
              <input id="price" name="price" type="number" step="0.01" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Color</label>
              <input id="color" name="color" type="text" class="form-control" required>
            </div>
            <div class="mb-3">
              <label class="form-label">Category</label>
              <select id="category" name="category" class="form-select">
                <option value="">Select category...</option>
                <% categories.forEach(function(c){ %>
                  <option value="<%= c.id %>"><%= c.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label">Description</label>
              <textarea id="description" name="description" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
              <label class="form-label">Image</label>
              <input id="imageFile" name="imageFile" type="file" accept="image/*" class="form-control">
              <input type="hidden" id="imageUrl" name="imageUrl">
              <div class="mt-2">
                <img id="img-preview" src="/images/placeholder-80.png" alt="preview" class="img-thumbnail" style="width:120px;height:120px;object-fit:cover">
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<script>
function applySort(value) {
  const params = new URLSearchParams(location.search);
  if (value) {
    const [sortBy, order] = value.split('_');
    params.set('sortBy', sortBy);
    params.set('order', order);
  } else {
    params.delete('sortBy');
    params.delete('order');
  }
  params.set('page', 1);
  window.location = '/?' + params.toString();
}

function buildQueryString(params) {
  const p = new URLSearchParams();
  Object.entries(params).forEach(([k, v]) => { if (v) p.set(k, v); });
  return p.toString();
}
</script>

<%- include('partials/footer') %>
